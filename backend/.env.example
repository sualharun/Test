# Required. For local dev you may use a long random string; for production use a secret manager.
# Example: openssl rand -hex 32
TASKBOARD_SECRET_KEY=
TASKBOARD_DATABASE_URL=sqlite:///./taskboard.db
# Optional: comma-separated origins (defaults to localhost dev ports if unset)
# TASKBOARD_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
